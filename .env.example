# META / INSTAGRAM
META_ACCESS_TOKEN=dein_access_token_hier
META_APP_ID=359892841436528
META_APP_SECRET=dein_app_secret_hier

# CANVA
CANVA_CLIENT_ID=deine_canva_client_id_hier
CANVA_CLIENT_SECRET=dein_canva_client_secret_hier

# OPTIONAL (wird automatisch gefunden wenn leer)
INSTAGRAM_BUSINESS_ACCOUNT_ID=

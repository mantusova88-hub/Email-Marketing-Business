# ============================================
# API-KEYS — KOPIERE DIESE DATEI ALS .env
# UND FÜLLE DIE WERTE AUS
# ============================================
# WICHTIG: .env wird NIEMALS in Git hochgeladen!

# --- ACTIVECAMPAIGN ---
# Zu finden unter: Einstellungen → Entwickler → API-Zugang
AC_API_URL=https://DEINNAME.api-us1.com
AC_API_KEY=DEIN_ACTIVECAMPAIGN_API_KEY

# --- SYSTEME.IO ---
# Zu finden unter: Einstellungen → API
SYSTEME_API_KEY=DEIN_SYSTEME_IO_API_KEY

# --- NOTION ---
# Integration erstellen unter: notion.so/my-integrations
NOTION_TOKEN=secret_DEIN_NOTION_INTEGRATION_TOKEN
# Datenbank-IDs (aus der URL deiner Notion-Datenbank)
NOTION_POSTS_DB_ID=DEINE_POSTS_DATENBANK_ID
NOTION_TASKS_DB_ID=DEINE_AUFGABEN_DATENBANK_ID

# --- ALLGEMEIN ---
# Dein Name wie Claude dich ansprechen soll
DEIN_NAME=Dein Name
